# Never commit a real bot token. Revoke any token that was shared publicly.
BOT_TOKEN=replace_with_new_botfather_token
BOT_USERNAME=spiiiikebot

# Public channel link https://t.me/spiiiike03 maps to @spiiiike03.
CHANNEL_USERNAME=@spiiiike03
PUBLIC_CHANNEL_URL=https://t.me/spiiiike03

# Use a pooled Neon Postgres connection string on Vercel.
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require

# Random strings. Use different values.
WEBHOOK_SECRET=replace_with_random_webhook_secret
SETUP_SECRET=replace_with_random_setup_secret

# Your numeric Telegram user id, comma-separated if there are multiple admins.
ADMIN_IDS=8606512131

INVITE_TARGET=5
MAX_REWARDS_PER_INVITER=50
REPORT_TIMEZONE=Asia/Shanghai

# Required only when running npm run set-webhook locally.
WEBHOOK_URL=https://your-vercel-project.vercel.app/api/webhook
